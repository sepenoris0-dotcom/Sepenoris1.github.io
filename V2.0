<!DOCTYPE html>
<html>
<head>
    <title>KULUNA VS PNC v2.0 - GTA Kinshasa</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: Arial; }
        canvas { display: block; margin: 0 auto; }
        #score { position: absolute; top: 10px; left: 10px; color: gold; font-size: 28px; font-weight: bold; text-shadow: 2px 2px 4px #000; }
        #lives { position: absolute; top: 10px; right: 10px; color: red; font-size: 28px; font-weight: bold; text-shadow: 2px 2px 4px #000; }
        #gameOver { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: white; font-size: 40px; text-align: center; display: none; background: rgba(0,0,0,0.9); padding: 30px; border: 3px solid gold; }
    </style>
</head>
<body>
    <div id="score">FC: 0</div>
    <div id="lives">❤️❤️❤️</div>
    <div id="gameOver">GAME OVER<br><span style="font-size:20px">Tap pour rejouer</span></div>
    <canvas id="game"></canvas>

<script>
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

// Chargement des sprites
const baronImg = new Image(); baronImg.src = 'baron.png';
const gombeImg = new Image(); gombeImg.src = 'gombe.jpg';
const jeepImg = new Image(); jeepImg.src = 'https://i.imgur.com/8QfYKjL.png'; // Jeep PNC temporaire

let kuluna = { x: canvas.width/2, y: canvas.height-120, w: 70, h: 100, speed: 8 };
let jeeps = [];
let billets = [];
let score = 0;
let lives = 3;
let gameRunning = true;

function drawBackground() {
    ctx.drawImage(gombeImg, 0, 0, canvas.width, canvas.height);
}

function drawKuluna() {
    ctx.drawImage(baronImg, kuluna.x, kuluna.y, kuluna.w, kuluna.h);
}

function spawnJeep() {
    jeeps.push({ x: Math.random()*(canvas.width-80), y: -120, w: 80, h: 120, speed: 4+Math.random()*3 });
}

function spawnBillet() {
    billets.push({ x: Math.random()*(canvas.width-40), y: -40, w: 40, h: 20, speed: 3 });
}

function update() {
    if (!gameRunning) return;

    // Jeeps PNC
    jeeps.forEach((j, i) => {
        j.y += j.speed;
        ctx.drawImage(jeepImg, j.x, j.y, j.w, j.h);
        if (j.y > canvas.height) jeeps.splice(i,1);

        // Collision
        if (kuluna.x < j.x+j.w && kuluna.x+kuluna.w > j.x &&
            kuluna.y < j.y+j.h && kuluna.y+kuluna.h > j.y) {
            lives--;
            jeeps.splice(i,1);
            document.getElementById('lives').innerHTML = '❤️'.repeat(lives);
            if (lives <= 0) endGame();
        }
    });

    // Billets FC
    billets.forEach((b, i) => {
        b.y += b.speed;
        ctx.fillStyle = 'lime';
        ctx.fillRect(b.x, b.y, b.w, b.h);
        ctx.fillStyle = 'black';
        ctx.font = 'bold 12px Arial';
        ctx.fillText('FC', b.x+10, b.y+15);
        if (b.y > canvas.height) billets.splice(i,1);

        if (kuluna.x < b.x+b.w && kuluna.x+kuluna.w > b.x &&
            kuluna.y < b.y+b.h && kuluna.y+kuluna.h > b.y) {
            score += 100;
            billets.splice(i,1);
            document.getElementById('score').innerText = 'FC: ' + score;
        }
    });
}

function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height);
    drawBackground();
    drawKuluna();
    update();
    if (gameRunning) requestAnimationFrame(draw);
}

// Contrôles
document.addEventListener('touchmove', e => {
    e.preventDefault();
    kuluna.x = e.touches[0].clientX - kuluna.w/2;
}, {passive: false});

document.addEventListener('touchstart', e => {
    if (!gameRunning) location.reload();
});

function endGame() {
    gameRunning = false;
    document.getElementById('gameOver').style.display = 'block';
}

setInterval(spawnJeep, 1200);
setInterval(spawnBillet, 1800);

// Lance le jeu quand les images sont chargées
baronImg.onload = () => { draw(); };
</script>
</body>
</html>
